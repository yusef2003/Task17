@model CinemaDashboard.ViewModels.Identity.EditProfileVM
@{ ViewData["Title"] = "My Profile"; }

<style>
    .profile-wrap { max-width: 700px; margin: 3rem auto; padding: 0 1rem; }
    .profile-card { background: #111827; border: 1px solid rgba(255,255,255,0.08); border-radius: 14px; padding: 2rem; color: #f1f5f9; }
    .profile-card h2 { font-size: 1.4rem; font-weight: 700; margin-bottom: 1.5rem; color: #60a5fa; }
    .form-label { color: #94a3b8; font-size: .85rem; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; }
    .form-control { background: #1e293b; border: 1px solid #334155; color: #f1f5f9; border-radius: 8px; padding: .65rem 1rem; }
    .form-control:focus { background: #1e293b; border-color: #60a5fa; color: #f1f5f9; box-shadow: 0 0 0 3px rgba(96,165,250,.15); }
    .btn-save { background: #2563eb; color: #fff; border: none; border-radius: 8px; padding: .7rem 2rem; font-weight: 600; }
    .btn-save:hover { background: #1d4ed8; color:#fff; }
    .tab-links { display: flex; gap: 1rem; margin-bottom: 2rem; }
    .tab-links a { color: #94a3b8; text-decoration: none; font-weight: 600; padding: .5rem 1.2rem; border-radius: 8px; }
    .tab-links a.active, .tab-links a:hover { background: #1e293b; color: #60a5fa; }
</style>

<div class="profile-wrap">
    <div class="tab-links">
        <a href="/Identity/Account/Profile" class="active">👤 Profile Info</a>
        <a href="/Identity/Account/ChangePassword">🔑 Change Password</a>
    </div>
    <div class="profile-card">
        <h2>👤 Edit Profile</h2>
        @if (TempData["Success-Notification"] != null)
        {
            <div class="alert alert-success">@TempData["Success-Notification"]</div>
        }
        <form asp-action="Profile" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="mb-3">
                <label asp-for="FullName" class="form-label"></label>
                <input asp-for="FullName" class="form-control" placeholder="Your full name" />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Address" class="form-label"></label>
                <input asp-for="Address" class="form-control" placeholder="Your address" />
            </div>
            <div class="mb-3">
                <label asp-for="PhoneNumber" class="form-label"></label>
                <input asp-for="PhoneNumber" class="form-control" placeholder="01x xxxx xxxx" />
            </div>
            <button type="submit" class="btn btn-save mt-2">💾 Update Profile</button>
        </form>
    </div>
</div>

@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
