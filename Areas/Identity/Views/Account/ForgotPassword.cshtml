@model CinemaDashboard.ViewModels.Identity.ForgotPasswordVM
@{ ViewData["Title"] = "Forgot Password"; Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Forgot Password — Cinema</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body>
<partial name="_AuthShared" />

<div class="auth-wrap">
  <div class="auth-box">

    <div class="auth-logo">
      <span class="auth-logo-icon">🔑</span>
      <div class="auth-logo-title">Cinema</div>
      <div class="auth-logo-sub">Reset your password</div>
    </div>

    <div class="auth-card">
      <div class="auth-card-header">
        <h2>Forgot Password?</h2>
        <p>Enter your email and we'll send you a reset link</p>
      </div>

      <form method="post" class="auth-card-body">
        <div asp-validation-summary="ModelOnly" class="auth-alert auth-alert-error"></div>

        <div class="auth-field">
          <label asp-for="Email" class="auth-label"></label>
          <input asp-for="Email" class="auth-input" placeholder="you@example.com" autocomplete="email" />
          <span asp-validation-for="Email" class="field-validation-error"></span>
        </div>

        <button type="submit" class="auth-submit">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          Send Reset Link
        </button>
      </form>

      <div class="auth-links">
        Remembered it? <a href="/Identity/Account/Login">Back to sign in</a>
      </div>
    </div>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<partial name="_ValidationScriptsPartial" />
</body>
</html>
