@model CinemaDashboard.ViewModels.Identity.ResetPasswordVM
@{ ViewData["Title"] = "Reset Password"; Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Reset Password — Cinema</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body>
<partial name="_AuthShared" />

<div class="auth-wrap">
  <div class="auth-box">

    <div class="auth-logo">
      <span class="auth-logo-icon">🔐</span>
      <div class="auth-logo-title">Cinema</div>
      <div class="auth-logo-sub">Choose a new password</div>
    </div>

    <div class="auth-card">
      <div class="auth-card-header">
        <h2>Reset Password</h2>
        <p>Enter your new password below</p>
      </div>

      <form method="post" class="auth-card-body">
        <input asp-for="Token" type="hidden" />
        <input asp-for="Email" type="hidden" />

        <div asp-validation-summary="ModelOnly" class="auth-alert auth-alert-error"></div>

        <div class="auth-field">
          <label asp-for="NewPassword" class="auth-label"></label>
          <input asp-for="NewPassword" class="auth-input" placeholder="Min. 6 characters" autocomplete="new-password" />
          <span asp-validation-for="NewPassword" class="field-validation-error"></span>
        </div>

        <div class="auth-field">
          <label asp-for="ConfirmPassword" class="auth-label"></label>
          <input asp-for="ConfirmPassword" class="auth-input" placeholder="Repeat new password" autocomplete="new-password" />
          <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
        </div>

        <button type="submit" class="auth-submit">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          Save New Password
        </button>
      </form>

      <div class="auth-links">
        <a href="/Identity/Account/Login">Back to sign in</a>
      </div>
    </div>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<partial name="_ValidationScriptsPartial" />
</body>
</html>
