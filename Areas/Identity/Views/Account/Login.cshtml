@model CinemaDashboard.ViewModels.Identity.LoginVM
@{ ViewData["Title"] = "Login"; Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Login — Cinema</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body>
<partial name="_AuthShared" />

<div class="auth-wrap">
  <div class="auth-box">

    <div class="auth-logo">
      <span class="auth-logo-icon">🎬</span>
      <div class="auth-logo-title">Cinema</div>
      <div class="auth-logo-sub">Sign in to your account</div>
    </div>

    @if (TempData["Info"] != null)
    {
      <div class="auth-alert auth-alert-info mb-3">ℹ️ @TempData["Info"]</div>
    }
    @if (TempData["Error"] != null)
    {
      <div class="auth-alert auth-alert-error mb-3">⚠️ @TempData["Error"]</div>
    }
    @if (TempData["Success-Notification"] != null)
    {
      <div class="auth-alert auth-alert-success mb-3">✅ @TempData["Success-Notification"]</div>
    }

    <div class="auth-card">
      <div class="auth-card-header">
        <h2>Welcome Back</h2>
        <p>Enter your credentials to continue</p>
      </div>

      <form method="post" asp-action="Login" asp-route-returnUrl="@ViewBag.ReturnUrl" class="auth-card-body">
        <div asp-validation-summary="ModelOnly" class="auth-alert auth-alert-error"></div>

        <div class="auth-field">
          <label asp-for="Email" class="auth-label"></label>
          <input asp-for="Email" class="auth-input" placeholder="you@example.com" autocomplete="email" />
          <span asp-validation-for="Email" class="field-validation-error"></span>
        </div>

        <div class="auth-field">
          <div style="display:flex;justify-content:space-between;align-items:center">
            <label asp-for="Password" class="auth-label"></label>
            <a href="/Identity/Account/ForgotPassword" style="font-size:.72rem;color:var(--silver);text-decoration:none;">Forgot password?</a>
          </div>
          <input asp-for="Password" class="auth-input" placeholder="Your password" autocomplete="current-password" />
          <span asp-validation-for="Password" class="field-validation-error"></span>
        </div>

        <label class="auth-checkbox-row">
          <input asp-for="RememberMe" type="checkbox" />
          Remember me for 30 days
        </label>

        <button type="submit" class="auth-submit">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
          Sign In
        </button>

        <div class="auth-divider">or</div>
      </form>

      <div class="auth-links">
        Don't have an account? <a href="/Identity/Account/Register">Register now</a>
        <br><br>
        Didn't receive confirmation email? <a href="/Identity/Account/ResendEmailConfirmation">Resend it</a>
      </div>
    </div>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<partial name="_ValidationScriptsPartial" />
</body>
</html>
