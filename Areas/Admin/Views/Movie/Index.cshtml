@model IEnumerable<Movie>
@{ ViewData["Title"] = "Movies"; }
<div class="d-flex justify-content-between align-items-center mb-3"><h2>Movies</h2><a class="btn btn-success" href="/Admin/Movie/Create">Create</a></div>
<div class="card mb-3"><div class="card-body">
<form method="get" class="row g-2">
<div class="col-md-2"><input class="form-control" name="MovieName" placeholder="Movie Name" value="@ViewBag.MovieName" /></div>
<div class="col-md-2"><input class="form-control" name="MinPrice" placeholder="Min Price" value="@ViewBag.MinPrice" /></div>
<div class="col-md-2"><input class="form-control" name="MaxPrice" placeholder="Max Price" value="@ViewBag.MaxPrice" /></div>
<div class="col-md-2"><select class="form-control" name="CategoryId"><option value="0">Category</option>@foreach(var c in ViewBag.Categories){<option value="@c.Id" selected="@(ViewBag.CategoryId == c.Id)">@c.Name</option>}</select></div>
<div class="col-md-2"><select class="form-control" name="CinemaId"><option value="0">Cinema</option>@foreach(var c in ViewBag.Cinemas){<option value="@c.Id" selected="@(ViewBag.CinemaId == c.Id)">@c.Name</option>}</select></div>
<div class="col-md-1 form-check pt-2"><input class="form-check-input" type="checkbox" name="IsUpcoming" value="true" @(ViewBag.IsUpcoming != null ? "checked" : "") /> <label>Upcoming</label></div>
<div class="col-md-1"><button class="btn btn-primary w-100">Filter</button></div>
</form></div></div>
<div class="card"><div class="card-body"><table class="table table-hover">
<thead><tr><th>Id</th><th>Image</th><th>Name</th><th>Price</th><th>DateTime</th><th>Category</th><th>Cinema</th><th>Status</th><th>Actions</th></tr></thead><tbody>
@foreach (var item in Model) {
<tr>
<td>@item.Id</td><td><img src="~/images/movieImages/@item.MainImg" width="60" /></td><td>@item.Name</td><td>EGP @item.Price</td><td>@item.DateTime.ToString("dd MMM yyyy HH:mm")</td><td>@item.Category.Name</td><td>@item.Cinema.Name</td>
<td><span class="badge @(item.Status ? "text-bg-success" : "text-bg-danger")">@(item.Status ? "Active" : "InActive")</span></td>
<td><a class="btn btn-warning btn-sm" href="/Admin/Movie/Update/@item.Id">Update</a> <a class="btn btn-danger btn-sm btn-delete" href="/Admin/Movie/Delete/@item.Id">Delete</a></td>
</tr>
}
</tbody></table></div></div>
<nav class="mt-3"><ul class="pagination justify-content-center">@for(int i=1;i<=ViewBag.TotalPages;i++){<li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")"><a class="page-link" href="/Admin/Movie/Index?Page=@i&MovieName=@ViewBag.MovieName&MinPrice=@ViewBag.MinPrice&MaxPrice=@ViewBag.MaxPrice&CategoryId=@ViewBag.CategoryId&CinemaId=@ViewBag.CinemaId">@i</a></li>}</ul></nav>
@section Scripts { <partial name="_NotificationPartial" /><script>document.querySelectorAll(".btn-delete").forEach(b=>b.onclick=e=>{e.preventDefault();Swal.fire({title:"Delete?",icon:"warning",showCancelButton:true}).then(r=>{if(r.isConfirmed) location.href=b.href;});});</script> }
