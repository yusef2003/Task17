@model IEnumerable<Category>
@{ ViewData["Title"] = "Categories"; }
<div class="d-flex justify-content-between align-items-center mb-3"><h2>Categories</h2><a class="btn btn-success" href="/Admin/Category/Create">Create</a></div>
<div class="card"><div class="card-body"><table class="table table-hover">
<thead><tr><th>Id</th><th>Name</th><th>Description</th><th>Status</th><th>Actions</th></tr></thead>
<tbody>
@foreach (var item in Model) {
<tr>
<td>@item.Id</td><td>@item.Name</td><td>@item.Description</td>
<td><span class="badge @(item.Status ? "text-bg-success" : "text-bg-danger")">@(item.Status ? "Active" : "InActive")</span></td>
<td><a class="btn btn-warning btn-sm" href="/Admin/Category/Update/@item.Id">Update</a> <a class="btn btn-danger btn-sm btn-delete" href="/Admin/Category/Delete/@item.Id">Delete</a></td>
</tr>
}
</tbody></table></div></div>
@section Scripts { <partial name="_NotificationPartial" /><script>document.querySelectorAll(".btn-delete").forEach(b=>b.onclick=e=>{e.preventDefault();Swal.fire({title:"Delete?",icon:"warning",showCancelButton:true}).then(r=>{if(r.isConfirmed) location.href=b.href;});});</script> }
