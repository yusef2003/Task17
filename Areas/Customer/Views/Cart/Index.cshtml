@model List<CinemaDashboard.Models.CartItem>
@{ ViewData["Title"] = "My Cart"; }

<style>
    :root { --gold:#c9972c; --ink:#0a0b0f; --ink2:#12141c; --ink3:#1c1f2e; --rim:#252a3a; --silver:#8a95b0; --white:#f0f2f8; }
    .cart-wrap { max-width: 900px; margin: 3rem auto; padding: 0 1.5rem; font-family: 'Outfit', sans-serif; color: var(--white); }
    .cart-wrap h1 { font-size: 2rem; font-weight: 800; margin-bottom: 2rem; }
    .cart-item { display: flex; align-items: center; gap: 1.2rem; background: var(--ink2); border: 1px solid var(--rim); border-radius: 10px; padding: 1rem 1.2rem; margin-bottom: 1rem; }
    .cart-item img { width: 60px; height: 85px; object-fit: cover; border-radius: 6px; }
    .cart-item-info { flex: 1; }
    .cart-item-name { font-size: 1.05rem; font-weight: 700; }
    .cart-item-price { color: var(--gold); font-size: .9rem; margin-top: .2rem; }
    .qty-form { display: flex; align-items: center; gap: .5rem; }
    .qty-input { width: 65px; background: var(--ink3); border: 1px solid var(--rim); color: var(--white); border-radius: 6px; padding: .35rem .6rem; text-align: center; }
    .btn-update { background: #2563eb; color: #fff; border: none; border-radius: 6px; padding: .35rem .9rem; font-size: .8rem; cursor: pointer; }
    .btn-remove { background: #dc2626; color: #fff; border: none; border-radius: 6px; padding: .35rem .9rem; font-size: .8rem; cursor: pointer; }
    .cart-summary { background: var(--ink2); border: 1px solid var(--rim); border-radius: 10px; padding: 1.5rem; margin-top: 1.5rem; }
    .cart-total { font-size: 1.4rem; font-weight: 800; color: var(--gold); }
    .btn-checkout { background: var(--gold); color: var(--ink); border: none; border-radius: 8px; padding: .8rem 2rem; font-weight: 700; font-size: 1rem; cursor: pointer; margin-top: 1rem; }
    .btn-clear { background: transparent; border: 1px solid var(--rim); color: var(--silver); border-radius: 8px; padding: .8rem 1.5rem; font-size: .9rem; cursor: pointer; margin-top: 1rem; margin-left: .5rem; }
    .empty-cart { text-align: center; padding: 5rem 2rem; color: var(--silver); }
    .empty-cart .icon { font-size: 4rem; margin-bottom: 1rem; }
</style>

<div class="cart-wrap">
    <h1>🛒 My Cart</h1>

    @if (!Model.Any())
    {
        <div class="empty-cart">
            <div class="icon">🎟️</div>
            <h3>Your cart is empty</h3>
            <p>Browse movies and add tickets to your cart.</p>
            <a href="/Customer/Home/Index" class="btn btn-warning mt-3">Browse Movies</a>
        </div>
    }
    else
    {
        @foreach (var item in Model)
        {
            <div class="cart-item">
                <img src="/images/movieImages/@item.MainImg" alt="@item.MovieName" />
                <div class="cart-item-info">
                    <div class="cart-item-name">@item.MovieName</div>
                    <div class="cart-item-price">EGP @item.Price per ticket</div>
                </div>
                <form method="post" action="/Customer/Cart/UpdateQuantity" class="qty-form">
                    <input type="hidden" name="movieId" value="@item.MovieId" />
                    <input type="number" name="quantity" value="@item.Quantity" min="0" max="20" class="qty-input" />
                    <button type="submit" class="btn-update">Update</button>
                </form>
                <form method="post" action="/Customer/Cart/Remove">
                    <input type="hidden" name="movieId" value="@item.MovieId" />
                    <button type="submit" class="btn-remove">Remove</button>
                </form>
            </div>
        }

        <div class="cart-summary">
            <div>Total: <span class="cart-total">EGP @ViewBag.Total</span></div>
            <button class="btn-checkout">✅ Checkout</button>
            <form method="post" action="/Customer/Cart/Clear" style="display:inline">
                <button type="submit" class="btn-clear">🗑 Clear Cart</button>
            </form>
        </div>
    }
</div>

@if (TempData["Success-Notification"] != null)
{
    @section Scripts {
        <script>toastr.success('@TempData["Success-Notification"]')</script>
    }
}
