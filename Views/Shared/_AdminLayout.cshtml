<!DOCTYPE html>
<html lang="en-US">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - CineAdmin</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet">
    <script src="https://kit.fontawesome.com/4bb7a60e3b.js" crossorigin="anonymous"></script>
    <style>
        body { font-family: 'Inter', sans-serif; background: #0b1220; color: #f1f5f9; }
        .admin-sidebar { background: linear-gradient(180deg, #020617, #0b1220); border-right: 1px solid rgba(255,255,255,0.08); }
        .admin-sidebar .navbar-brand { color: #60a5fa; font-weight: 700; font-size: 1.2rem; }
        .admin-sidebar .nav-link { color: #e2e8f0; padding: 10px 12px; border-radius: 8px; transition: 0.25s; }
        .admin-sidebar .nav-link:hover { background: rgba(96,165,250,0.2); color: #ffffff; transform: translateX(4px); }
        .admin-sidebar hr { border-color: rgba(255,255,255,0.08); }
        .topbar { background: #111827; border-bottom: 1px solid rgba(255,255,255,0.08); }
        .topbar span { color: #f9fafb; font-size: 0.95rem; }
        .content-area { background: #020617; min-height: 100vh; }
        .content-wrapper { padding: 25px; }
        .card { background: #111827; border-radius: 12px; border: 1px solid rgba(255,255,255,0.05); box-shadow: 0 8px 25px rgba(0,0,0,0.4); color: #f1f5f9; }
        .badge { background: #60a5fa !important; color: #020617 !important; font-weight: 500; }
        .btn-logout { background: transparent; border: 1px solid rgba(255,255,255,0.15); color: #94a3b8; border-radius: 6px; padding: .35rem .9rem; font-size: .82rem; cursor: pointer; transition: .2s; }
        .btn-logout:hover { border-color: #ef4444; color: #ef4444; }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row min-vh-100">
            <!-- SIDEBAR -->
            <nav class="col-12 col-lg-2 admin-sidebar p-4">
                <a class="navbar-brand d-flex align-items-center mb-4" href="/Admin/Home/Index">
                    <span class="me-2">🎬</span><span>Cinema</span>
                </a>
                <div class="small text-uppercase text-secondary mb-3">Management</div>
                <ul class="nav flex-column gap-2">
                    <li><a class="nav-link" href="/Admin/Home/Index"><i class="fa-solid fa-chart-line me-2"></i> Overview</a></li>
                    <li><a class="nav-link" href="/Admin/Actor/Index"><i class="fa-solid fa-user me-2"></i> Cast</a></li>
                    <li><a class="nav-link" href="/Admin/Movie/Index"><i class="fa-solid fa-film me-2"></i> Films</a></li>
                    <li><a class="nav-link" href="/Admin/Category/Index"><i class="fa-solid fa-tags me-2"></i> Categories</a></li>
                    <li><a class="nav-link" href="/Admin/Cinema/Index"><i class="fa-solid fa-building me-2"></i> Cinemas</a></li>
                    @if (User.IsInRole("SuperAdmin"))
                    {
                        <li><a class="nav-link" href="/Admin/Users/Index"><i class="fa-solid fa-users me-2"></i> Users</a></li>
                    }
                </ul>
                <hr />
                <a class="nav-link" href="/Customer/Home/Index"><i class="fa-solid fa-globe me-2"></i> Public Site</a>
            </nav>

            <!-- MAIN -->
            <div class="col-12 col-lg-10 content-area">
                <!-- TOPBAR -->
                <div class="topbar d-flex justify-content-between align-items-center px-4 py-3">
                    <span class="fw-semibold">🎛 Dashboard</span>
                    <div class="d-flex align-items-center gap-3">
                        <span class="text-secondary small">👤 @User.Identity?.Name</span>
                        <a href="/Identity/Account/Profile" class="btn-logout">Profile</a>
                        <form action="/Identity/Account/Logout" method="post" style="display:inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-logout">🚪 Logout</button>
                        </form>
                    </div>
                </div>
                <!-- CONTENT -->
                <div class="content-wrapper">@RenderBody()</div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
